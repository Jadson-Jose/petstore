[run]
source = .
omit = 
    */venv/*
    */env/*
    */virtualenv/*
    */migrations/*
    */settings/*
    */static/*
    */media/*
    */node_modules/*
    */.git/*
    */tests/__init__.py
    manage.py
    */wsgi.py
    */asgi.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    def __str__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if settings.DEBUG
    if TYPE_CHECKING:

[html]
directory = htmlcov
title = Coverage Report